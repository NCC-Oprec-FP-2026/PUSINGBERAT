# ============================================================
# PUSINGBERAT SIEM - Environment Variables
#
# Copy this file before running the project locally:
#   cp .env.example .env
#
# Keep .env private. This file is documentation only and contains
# safe placeholder values.
# ============================================================


# ============================================================
# PostgreSQL container
# Used by the postgres service in docker-compose.dev.yml.
# ============================================================

# Database created by the postgres container on first boot.
POSTGRES_DB=pusingberat

# PostgreSQL user created on first boot.
POSTGRES_USER=siem

# Development password. Change this for shared/staging/prod environments.
# Keep this equal to DB_PASSWORD for the local compose stack.
POSTGRES_PASSWORD=siempass

# Host port exposed for psql, DBeaver, DataGrip, etc.
# Inside Docker, services still use port 5432.
POSTGRES_HOST_PORT=5432


# ============================================================
# Backend service (Go / Gin)
# These are read by backend/internal/config/config.go.
# ============================================================

# In Docker Compose, DB_HOST must be the postgres service name.
# If running the backend directly on your host, use localhost instead.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pusingberat
DB_USER=siem
DB_PASSWORD=siempass

# Port the Gin HTTP server listens on.
# config.go defaults to 8080 when this is omitted.
# If you change this, also update VITE_API_BASE_URL and VITE_WS_BASE_URL.
SERVER_PORT=8080

# Directory containing YAML detection rules.
# Docker Compose path:
RULES_DIR=/app/backend/rules
# Local host alternative:
# RULES_DIR=./rules

# Log verbosity. Valid values: debug, info, warn, error.
LOG_LEVEL=debug

# Discord incoming webhook URL for alert notifications.
# Leave blank to disable Discord notifications during development.
DISCORD_WEBHOOK_URL=


# ============================================================
# Frontend service (Vue 3 / Vite)
# Vite only exposes browser-side variables prefixed with VITE_.
# ============================================================

# Browser-facing REST API base URL.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Browser-facing WebSocket base URL for real-time alerts.
VITE_WS_BASE_URL=ws://localhost:8080/ws

# Polling helps Vite HMR detect file changes through Docker bind mounts.
CHOKIDAR_USEPOLLING=true


# ============================================================
# Flask frontend-server service
# Used by frontend-server/app.py and the flask service in compose.
# ============================================================

# Flask dev mode value used by the compose service.
FLASK_ENV=development

# Internal Docker URL for the Vite dev server.
VITE_DEV_SERVER_URL=http://frontend:5173

# Internal Docker URL for the backend API.
BACKEND_API_URL=http://backend:8080/api/v1
