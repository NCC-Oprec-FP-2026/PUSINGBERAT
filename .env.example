# ============================================================
# PUSINGBERAT SIEM — Environment Variables
# .env.example  (commit this file — it has NO real secrets)
#
# SETUP:
#   cp .env.example .env
#   Edit .env with real values. NEVER commit .env to git.
# ============================================================


# ============================================================
# POSTGRESQL
# These are shared between the postgres container and the backend
# container, which connects using the service name "postgres".
# ============================================================

# Database name created on first boot
POSTGRES_DB=pusingberat

# Superuser for the postgres container
POSTGRES_USER=siem

# CHANGE THIS — pick a strong password before first run
POSTGRES_PASSWORD=changeme_strong_password_here

# Port exposed on the Docker host (for psql / DBeaver / DataGrip access)
# The backend always connects on the internal Docker port 5432.
POSTGRES_HOST_PORT=5432


# ============================================================
# BACKEND (Go / Gin)
# These map to the Config struct in internal/config/config.go.
# ============================================================

# DB connection — backend uses these directly (NOT POSTGRES_* vars above)
# DB_HOST must match the docker-compose service name so Docker DNS resolves it.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pusingberat
DB_USER=siem
DB_PASSWORD=changeme_strong_password_here

# Port the Gin HTTP server listens on inside the container
BACKEND_PORT=8080

# Path inside the backend container where YAML rule files live
RULES_DIR=/app/rules

# Structured log output level: debug | info | warn | error
LOG_LEVEL=debug

# Discord incoming webhook URL for alert notifications.
# Leave blank to disable Discord notifications during early dev.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_WITH_REAL_ID/REPLACE_WITH_REAL_TOKEN

# Maximum number of PostgreSQL connections in the pool
DB_MAX_CONNS=10

# CORS — comma-separated list of allowed frontend origins.
# In dev, this covers both the Vite dev server and Flask server.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000


# ============================================================
# FRONTEND (Vue 3 / Vite)
# Variables MUST be prefixed with VITE_ to be accessible in
# browser-side code (Vite strips all other env vars at build time).
# ============================================================

# Base URL of the Go backend API.
# In dev with docker-compose: the browser calls localhost (not the service name).
VITE_API_BASE_URL=http://localhost:8080

# WebSocket endpoint for real-time alert streaming.
VITE_WS_URL=ws://localhost:8080/ws

# App display name shown in the browser tab and sidebar
VITE_APP_NAME=PUSINGBERAT SIEM


# ============================================================
# FLASK (frontend-server)
# ============================================================

# Dev mode: enables Werkzeug auto-reloader and detailed error pages.
# Set to "0" or remove this line for production.
FLASK_DEBUG=1

# Bind address inside the container — 0.0.0.0 required for Docker.
FLASK_RUN_HOST=0.0.0.0

# Port the Flask dev server listens on
FLASK_RUN_PORT=5000