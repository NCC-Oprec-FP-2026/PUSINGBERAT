meta {
  name: List Alerts
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/v1/alerts
  body: none
  auth: none
}

params:query {
  page: 1
  per_page: 20
}

assert {
  res.status: eq 200
  res.body.data: isDefined
}

script:post-response {
  const data = res.getBody();
  if (data && data.data && data.data.length > 0) {
    bru.setVar("alert_id", data.data[0].id);
  }
}
