meta {
  name: List Events
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/v1/events
  body: none
  auth: none
}

params:query {
  page: 1
  per_page: 20
  ~level: error
  ~search: error
  ~source_id: 
  ~from: 
  ~to: 
}

assert {
  res.status: eq 200
  res.body.data: isDefined
}

script:post-response {
  const data = res.getBody();
  if (data && data.data && data.data.length > 0) {
    bru.setVar("event_id", data.data[0].id);
  }
}
