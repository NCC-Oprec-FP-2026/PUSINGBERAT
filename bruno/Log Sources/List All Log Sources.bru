meta {
  name: List All Log Sources
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/v1/sources
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data: isDefined
}

script:post-response {
  const data = res.getBody();
  if (data && data.data && data.data.length > 0) {
    bru.setVar("source_id", data.data[0].id);
  }
}
