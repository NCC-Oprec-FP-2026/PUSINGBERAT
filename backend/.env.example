# ============================================================
# PUSINGBERAT Backend Environment
#
# Use this when running the Go backend directly from backend/.
# For the full Docker stack, prefer the root .env.example.
# ============================================================

# PostgreSQL connection.
# Use localhost when running the backend on your host machine.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pusingberat
DB_USER=siem
DB_PASSWORD=siempass

# Gin HTTP server port. Defaults to 8080 if omitted.
SERVER_PORT=8080

# Directory containing YAML detection rule files.
RULES_DIR=./rules

# Log verbosity. Valid values: debug, info, warn, error.
LOG_LEVEL=debug

# Discord incoming webhook URL for alert notifications.
# Leave blank to disable Discord notifications during local dev.
DISCORD_WEBHOOK_URL=
